{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2021",
    "outDir": "dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "skipLibCheck": true,
    "strictNullChecks": false
  },
  "include": ["src/**/*"]
}
